<idea-plugin>
    <id>com.fish.chat.plugin.intelliJPlugin</id>
    <name>Fish Chat</name>
    <vendor url="https://github.com/fish-chat">Fish Chat</vendor>

    <description><![CDATA[
        Fish Chat client for IntelliJ IDEA.<br>
        A geek-style instant messaging plugin with log-style chat UI.
    ]]></description>

    <depends>com.intellij.modules.compose</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="FishChat" factoryClass="com.fish.chat.plugin.intellijplugin.FishChatToolWindowFactory"
                    icon="AllIcons.Toolwindows.ToolWindowMessages"/>
    </extensions>
</idea-plugin>
