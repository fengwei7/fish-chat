# 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# MySQL 配置
DB_URL=jdbc:mysql://mysql:3306/fish_chat?serverTimezone=UTC&useUnicode=true&characterEncoding=utf-8
DB_USERNAME=root
DB_PASSWORD=YourSecurePassword123

# MongoDB 配置
MONGODB_URI=mongodb://mongo:27017/fishchat

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
