# 环境变量配置

# MySQL
DB_URL=jdbc:mysql://your_host:3306/fish_chat?serverTimezone=UTC&useUnicode=true&characterEncoding=utf-8&zeroDateTimeBehavior=convertToNull&allowMultiQueries=true&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# MongoDB
MONGODB_URI=mongodb://your_mongo_user:your_mongo_password@your_host:27017/fishchat

# Redis
REDIS_HOST=your_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
